APP_ENV=production
ORCHESTRATOR_NAME=blockrunnooor
ORCHESTRATOR_VERSION=0.1.0

GLOBAL_MAX_CONCURRENCY=5
PER_WALLET_MAX_CONCURRENCY=1
JITTER_MAX_SECONDS=120
MAX_ATTEMPTS=3
BACKOFF_BASE_SECONDS=2
CIRCUIT_BREAKER_FAILS=5
CIRCUIT_BREAKER_TTL_SECONDS=300

MAX_COST_PER_RUN_USD=0.20
MAX_COST_PER_DAY_USD=5.00

BLOCKRUN_BASE_URL=https://blockrun.ai/api
BLOCKRUN_WALLET_KEY=__REPLACE_ME__

KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_API_KEY=__REPLACE_ME__
KIMI_MODEL=k2.6

NOTION_TOKEN=__REPLACE_ME__
NOTION_RUNS_DATABASE_ID=__REPLACE_ME__
NOTION_WALLETS_DATABASE_ID=
NOTION_ERRORS_DATABASE_ID=

SECRETS_DIR=/var/lib/blockrunnooor/secrets
STATE_DIR=/var/lib/blockrunnooor/state
