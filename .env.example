BRNOO_LOG_LEVEL=INFO
BRNOO_ORCHESTRATOR_VERSION=dev
BRNOO_RUN_ID_SALT=change_me

BRNOO_STATE_DB_PATH=/var/lib/blockrunnooor/state/state.db
BRNOO_WALLET_IDS=wallet_001,wallet_002
BRNOO_TASK_TYPES=default
BRNOO_WALLETS_MANIFEST_PATH=/var/lib/blockrunnooor/wallets/manifest.jsonl
BRNOO_PROMPTS_FILE=/etc/blockrunnooor/prompts.jsonl
BRNOO_PROMPT_SELECTION_STRATEGY=random
BRNOO_DEFAULT_DAILY_BUDGET_USD=0.5
BRNOO_DEFAULT_MAX_COST_PER_RUN_USD=0.05

BRNOO_GLOBAL_MAX_CONCURRENCY=5
BRNOO_PER_WALLET_MAX_CONCURRENCY=1
BRNOO_BASE_INTERVAL_SECONDS=300
BRNOO_JITTER_MAX_SECONDS=60
BRNOO_BUCKET_SECONDS=300
BRNOO_WALLET_FAILURE_THRESHOLD=3
BRNOO_CIRCUIT_FAILURE_THRESHOLD=5
BRNOO_CIRCUIT_OPEN_SECONDS=300
BRNOO_OUTBOX_POLL_SECONDS=5

BRNOO_MAX_ATTEMPTS=3
BRNOO_BACKOFF_BASE_SECONDS=2
BRNOO_BACKOFF_MAX_SECONDS=60
BRNOO_WALLET_COOLDOWN_SECONDS=900

BRNOO_EXECUTOR_PATH=/opt/blockrunnooor/bin/executor
BRNOO_EXECUTOR_TIMEOUT_SECONDS=120

BRNOO_SECRETS_DIR=/var/lib/blockrunnooor/secrets
BRNOO_MASTER_KEY_B64=

BLOCKRUN_API_URL=https://blockrun.ai/api
BLOCKRUN_WALLET_KEY=
BLOCKRUN_TIMEOUT_SECONDS=30
BLOCKRUN_CHAT_PATH=/v1/chat/completions

NOTION_TOKEN=
NOTION_RUNS_DATABASE_ID=
NOTION_TIMEOUT_SECONDS=30
