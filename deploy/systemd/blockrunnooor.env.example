BRNOO_ORCHESTRATOR_VERSION=prod
BRNOO_RUN_ID_SALT=

BRNOO_STATE_DB_PATH=/var/lib/blockrunnooor/state/state.db
BRNOO_WALLET_IDS=
BRNOO_TASK_TYPES=default
BRNOO_DEFAULT_DAILY_BUDGET_USD=0.0
BRNOO_DEFAULT_MAX_COST_PER_RUN_USD=0.0

BRNOO_GLOBAL_MAX_CONCURRENCY=5
BRNOO_PER_WALLET_MAX_CONCURRENCY=1
BRNOO_BASE_INTERVAL_SECONDS=300
BRNOO_JITTER_MAX_SECONDS=60

BRNOO_MAX_ATTEMPTS=3
BRNOO_BACKOFF_BASE_SECONDS=2
BRNOO_BACKOFF_MAX_SECONDS=60
BRNOO_WALLET_COOLDOWN_SECONDS=900

BRNOO_EXECUTOR_PATH=/opt/blockrunnooor/bin/executor
BRNOO_EXECUTOR_TIMEOUT_SECONDS=120

BRNOO_SECRETS_DIR=/var/lib/blockrunnooor/secrets
BRNOO_MASTER_KEY_B64=

BLOCKRUN_BASE_URL=
BLOCKRUN_AUTH_TOKEN=
BLOCKRUN_TIMEOUT_SECONDS=30
BLOCKRUN_DEFAULT_PATH=/v1/run

NOTION_TOKEN=
NOTION_RUNS_DATABASE_ID=
NOTION_TIMEOUT_SECONDS=30
